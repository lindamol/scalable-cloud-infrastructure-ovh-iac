# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Real variable files — may contain project IDs or sensitive values
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Keep example variable files
!*.tfvars.example
!*.tfvars.json.example

# Terraform plan and crash files
*.tfplan
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Keep the Terraform provider lock file
!.terraform.lock.hcl

# Environment variables and credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Terraform CLI configuration may contain credentials
.terraformrc
terraform.rc

# Python
venv/
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# VS Code
.vscode/

# Logs
*.log
terraform/modules/**/.terraform.lock.hcl